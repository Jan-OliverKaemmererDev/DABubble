# Apache config for DABubble served from the root folder (e.g. httpdocs).
# Angular SPA fallback: deep links and the reset route must resolve to index.html instead of a 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route everything else to the app shell.
  RewriteRule ^ index.html [L]
</IfModule>
