/src/environments/environment.ts
/src/environments/environment.development.ts
.env
.env.*

# IDEs and editors
/.vscode
/.idea
.project
.classpath
*.launch
.settings/
*.sublime-workspace
.history/

# Operating system files
.DS_Store
Thumbs.db

# Local AI-assistant working artifacts (not part of the app)
/.claude
/.claude-tmp
CLAUDE.md
design-system.md
